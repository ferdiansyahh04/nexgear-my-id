{
  "name": "student/nexgear-store",
  "description": "Modern CodeIgniter 4 e-commerce project for gaming accessories.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "codeigniter4/framework": "^4.5"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Support\\": "tests/_support/"
    }
  },
  "scripts": {
    "serve": "php spark serve --host 127.0.0.1 --port 8080",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

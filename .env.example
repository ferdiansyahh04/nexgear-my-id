# ──────────────────────────────────────────────────────────
# NexGear Store — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and update values for your environment.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
# Set to 'production' when deploying to VPS
CI_ENVIRONMENT = development

# Update this to your domain in production (e.g., https://nexgear.my.id/)
app.baseURL = 'http://localhost:8080/'
app.indexPage = ''
app.appTimezone = 'Asia/Jakarta'

# ── Database ─────────────────────────────────────────────
# Use a STRONG password in production!
database.default.hostname = localhost
database.default.database = nexgear_store
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# ── Encryption ───────────────────────────────────────────
# Generate a new key with: php spark key:generate
encryption.key = hex2bin:CHANGE_THIS_RUN_PHP_SPARK_KEY_GENERATE

# ── Email (optional) ─────────────────────────────────────
# Leave email.SMTPHost empty to skip outbound mail. The MailerService will
# write would-be messages to writable/logs/mail.log instead so dev flows
# stay green without SMTP credentials.
#
# Mailtrap dev sandbox example:
#   email.protocol  = smtp
#   email.fromEmail = no-reply@nexgear.my.id
#   email.fromName  = NexGear Store
#   email.SMTPHost  = sandbox.smtp.mailtrap.io
#   email.SMTPUser  = your-mailtrap-user
#   email.SMTPPass  = your-mailtrap-pass
#   email.SMTPPort  = 2525
#   email.SMTPCrypto = tls
#
# email.protocol  = smtp
# email.fromEmail = no-reply@nexgear.my.id
# email.fromName  = NexGear Store
# email.SMTPHost  =
# email.SMTPUser  =
# email.SMTPPass  =
# email.SMTPPort  = 587
# email.SMTPCrypto = tls

# ── Payments (Midtrans Snap) ─────────────────────────────
# Grab the keys from the Midtrans dashboard → Settings → Access Keys.
# Use the Sandbox keys (prefixed "SB-") while testing; switch to the
# production keys and set production = true when going live.
#
# Leave these blank to disable online payment — checkout then falls back to
# the legacy "order saved, pay offline" flow, so the store still works.
#
# Dashboard endpoint settings to configure (Sandbox):
#   Payment Notification URL : https://nexgear.my.id/payment/notification
#   Finish Redirect URL      : https://nexgear.my.id/payment/finish
#   Unfinish Redirect URL    : https://nexgear.my.id/payment/unfinish
#   Error Redirect URL       : https://nexgear.my.id/payment/error
#
# midtrans.serverKey = SB-Mid-server-xxxxxxxxxxxxxxxx
# midtrans.clientKey = SB-Mid-client-xxxxxxxxxxxxxxxx
# midtrans.production = false
